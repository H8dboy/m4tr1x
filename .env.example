# M4TR1X - Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------

# Port the API server listens on
PORT=8080

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------

# API key required on every request (leave blank to disable auth)
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
M4TR1X_API_KEY=

# Comma-separated list of allowed CORS origins
# For local development you can add http://localhost:3000
ALLOWED_ORIGINS=https://h8dboy.github.io

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------

# Path to the SQLite database file
DB_PATH=m4tr1x.db

# Maximum video upload size in megabytes
MAX_FILE_SIZE_MB=100
